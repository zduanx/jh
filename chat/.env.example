# ============================================================================
# CHAT ENVIRONMENT VARIABLES - EXAMPLE (copy to .env.local)
# ============================================================================
#   cp .env.example .env.local
#
# This file is used for LOCAL DEVELOPMENT ONLY (.env.local is gitignored).
#
# For AWS Lambda deployment:
#   - Production values: VARIABLE_NAME_PROD_VALUE comments below
#   - CloudFormation metadata: PARAM_NAME, DESCRIPTION, NO_ECHO, DEFAULT
#   - Deployment config: See .sam-config file
#   - chat/scripts/generate_*.py auto-generate template.yaml and samconfig.toml
#
# Format for each variable:
#   VARIABLE_NAME=value
#   # VARIABLE_NAME_PROD_VALUE=value
#   # VARIABLE_NAME_PARAM_NAME=CloudFormationParameterName
#   # VARIABLE_NAME_DESCRIPTION=description for CloudFormation
#   # VARIABLE_NAME_NO_ECHO=true|false (hide value in CloudFormation logs)
#
# Lambda does NOT read this file. local.js loads .env.local for local dev; the
# generators read the metadata comments to build template.yaml / samconfig.toml.
# ============================================================================

# Local dev port for the chat Node server (default: 8100; local-only, no metadata)
CHAT_PORT=8100

# JWT Configuration
# MUST match the backend's SECRET_KEY (chat verifies the same signed tokens).
# Copy the value from backend/.env.local SECRET_KEY.
SECRET_KEY=copy-from-backend-env-local
# SECRET_KEY_PROD_VALUE=copy-from-backend-env-local
# SECRET_KEY_PARAM_NAME=JWTSecretKey
# SECRET_KEY_DESCRIPTION=Secret key for JWT signing (shared with backend)
# SECRET_KEY_NO_ECHO=true

# Upstash Redis (REST/HTTP) — ephemeral session store (Phase 6B).
# Get from the Upstash console → your DB → REST API section.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_URL_PROD_VALUE=https://your-db.upstash.io
# UPSTASH_REDIS_REST_URL_PARAM_NAME=UpstashRedisRestUrl
# UPSTASH_REDIS_REST_URL_NO_ECHO=false
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# UPSTASH_REDIS_REST_TOKEN_PROD_VALUE=your-upstash-token
# UPSTASH_REDIS_REST_TOKEN_PARAM_NAME=UpstashRedisRestToken
# UPSTASH_REDIS_REST_TOKEN_NO_ECHO=true

# MCP server (Phase 7C) — the chat agent is an MCP CLIENT of the 7B Python server.
# URL: local dev points at jbemcp (localhost:8001); prod points at the McpServer
# Lambda Function URL. (No _NO_ECHO — a URL is not a secret; PROD_VALUE is the
# deployed Function URL, fill after `jpushapi` prints McpServerUrl.)
MCP_SERVER_URL=http://localhost:8001
# MCP_SERVER_URL_PROD_VALUE=https://YOUR-mcp-function-url.lambda-url.us-east-1.on.aws
# MCP_SERVER_URL_PARAM_NAME=McpServerUrl
# MCP_SERVER_URL_DESCRIPTION=Base URL of the MCP server (Function URL in prod)
# MCP_SERVER_URL_NO_ECHO=false
#
# Service token (ADR-033) — MUST match backend/.env.local MCP_SERVICE_TOKEN.
# Authenticates the agent→MCP RPC (service-to-service, not the user JWT, not CORS).
MCP_SERVICE_TOKEN=copy-from-backend-env-local
# MCP_SERVICE_TOKEN_PROD_VALUE=copy-from-backend-env-local
# MCP_SERVICE_TOKEN_PARAM_NAME=McpServiceToken
# MCP_SERVICE_TOKEN_DESCRIPTION=Shared service token for MCP server auth (matches backend)
# MCP_SERVICE_TOKEN_NO_ECHO=true

# Anthropic API key (Phase 7C) — the chat agent's LLM (Claude). Pay-per-token.
# Get one at https://console.anthropic.com → API Keys → Create Key (needs billing).
# Starts with sk-ant-. NEVER commit it (this example uses a placeholder).
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
# ANTHROPIC_API_KEY_PROD_VALUE=sk-ant-REPLACE_WITH_YOUR_KEY
# ANTHROPIC_API_KEY_PARAM_NAME=AnthropicApiKey
# ANTHROPIC_API_KEY_DESCRIPTION=Anthropic API key for the chat agent (Claude)
# ANTHROPIC_API_KEY_NO_ECHO=true
# Optional overrides (have sensible defaults in anthropicClient.js):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=2048
