# ============================================================================
# CHAT ENVIRONMENT VARIABLES - EXAMPLE (copy to .env.local)
# ============================================================================
#   cp .env.example .env.local
#
# This file is used for LOCAL DEVELOPMENT ONLY (.env.local is gitignored).
#
# For AWS Lambda deployment:
#   - Production values: VARIABLE_NAME_PROD_VALUE comments below
#   - CloudFormation metadata: PARAM_NAME, DESCRIPTION, NO_ECHO, DEFAULT
#   - Deployment config: See .sam-config file
#   - chat/scripts/generate_*.py auto-generate template.yaml and samconfig.toml
#
# Format for each variable:
#   VARIABLE_NAME=value
#   # VARIABLE_NAME_PROD_VALUE=value
#   # VARIABLE_NAME_PARAM_NAME=CloudFormationParameterName
#   # VARIABLE_NAME_DESCRIPTION=description for CloudFormation
#   # VARIABLE_NAME_NO_ECHO=true|false (hide value in CloudFormation logs)
#
# Lambda does NOT read this file. local.js loads .env.local for local dev; the
# generators read the metadata comments to build template.yaml / samconfig.toml.
# ============================================================================

# Local dev port for the chat Node server (default: 8100; local-only, no metadata)
CHAT_PORT=8100

# JWT Configuration
# MUST match the backend's SECRET_KEY (chat verifies the same signed tokens).
# Copy the value from backend/.env.local SECRET_KEY.
SECRET_KEY=copy-from-backend-env-local
# SECRET_KEY_PROD_VALUE=copy-from-backend-env-local
# SECRET_KEY_PARAM_NAME=JWTSecretKey
# SECRET_KEY_DESCRIPTION=Secret key for JWT signing (shared with backend)
# SECRET_KEY_NO_ECHO=true

# --- Added in later phases (placeholders, not used in 6A) ---
# REDIS_URL=                # Phase 6B (Upstash) — keep out of git
# ANTHROPIC_API_KEY=        # Phase 7 — keep out of git
