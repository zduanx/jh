# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES - TEMPLATE
# ============================================================================
#
# This is a template for .env.local (which is gitignored)
#
# For Vercel deployment:
#   - Production values: Use REACT_APP_VARIABLE_NAME_PROD_VALUE comments
#   - jpushvercel script auto-updates Vercel environment variables
#
# Format:
#   REACT_APP_VARIABLE_NAME=local_value
#   # REACT_APP_VARIABLE_NAME_PROD_VALUE=production_value
#
# ============================================================================

# Backend API URL
# Local: Points to local FastAPI server
# Production: Points to AWS Lambda API Gateway endpoint
REACT_APP_API_URL=http://localhost:8000
# REACT_APP_API_URL_PROD_VALUE=https://your-lambda-api-url.execute-api.us-east-1.amazonaws.com/prod

# Chat backend URL (Phase 6C)
# Local: Points to the local chat Node server (jbenode, port 8100)
# Production: Points to the chat Lambda Function URL
REACT_APP_CHAT_URL=http://localhost:8100
# REACT_APP_CHAT_URL_PROD_VALUE=https://your-chat-function-url.lambda-url.us-east-1.on.aws

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# Note: Same client ID can be used for both local and production
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_CLIENT_ID_PROD_VALUE=your-google-client-id.apps.googleusercontent.com
