# ============================================================================
# UNIFIED ENVIRONMENT VARIABLES - TEMPLATE  (Phase 9B)
# ============================================================================
#
# Copy this to .env.local (gitignored) and fill in real values. ONE root file is
# the single source for ALL stacks — local dev (backend/chat/frontend), pytest,
# and Terraform deploys. The app loaders (backend/config/settings.py, chat/local.js)
# and tests read this root file; per-stack .env.local files no longer exist.
#
#   cp .env.example .env.local   &&   edit .env.local
#
# Format per deployable secret:
#   VARIABLE_NAME=local_value
#   # VARIABLE_NAME_PROD_VALUE=production_value   <- tfvars.sh / jsyncsecrets read this
#
# On deploy: tfvars.sh greps each `# NAME_PROD_VALUE=` listed in a stack's
# deploy.config.json and exports TF_VAR_<lowercase>; jsyncsecrets pushes the same to
# GitHub Secrets (9E CD). In Lambda there is no file — Terraform sets these as the
# function's OS env vars. Vercel (frontend) reads REACT_APP_* from its own store.
# ============================================================================


# ----------------------------------------------------------------------------
# BACKEND (FastAPI / Lambda)  — deploy.config.json: target=terraform
# ----------------------------------------------------------------------------

# Google OAuth — only the CLIENT_ID is needed (auth verifies Google ID tokens;
# the OAuth client *secret* is not used by this flow).
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_ID_PROD_VALUE=your-google-client-id.apps.googleusercontent.com

# JWT signing — generate with: openssl rand -hex 32. Shared by backend + chat.
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
# SECRET_KEY_PROD_VALUE=your-production-secret-key

# CORS — comma-separated URLs allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# ALLOWED_ORIGINS_PROD_VALUE=http://localhost:3000,https://your-vercel-app.vercel.app

# Access control — comma-separated emails allowed to authenticate
ALLOWED_EMAILS=your-email@gmail.com
# ALLOWED_EMAILS_PROD_VALUE=your-email@gmail.com

# Database (Neon PostgreSQL) — local points at the test/dev branch for safety
DATABASE_URL=postgresql://user:password@host-dev/neondb?sslmode=require
# DATABASE_URL_PROD_VALUE=postgresql://user:password@host-prod/neondb?sslmode=require

# Test database (pytest with isolated transactions; CI uses a runner-local Postgres)
TEST_DATABASE_URL=postgresql://user:password@host-dev/neondb?sslmode=require
# TEST_DATABASE_URL_PROD_VALUE=postgresql://user:password@host-dev/neondb?sslmode=require

# S3 resume storage — only needed for LOCAL dev (in AWS, Terraform sets the bucket).
# Format: jobhunt-resume-content-{your-aws-account-id}
RESUME_CONTENT_BUCKET=jobhunt-resume-content-YOUR_AWS_ACCOUNT_ID

# Voyage AI — embeddings for semantic job/resume matching (Phase 7A, ADR-032)
# Get a key (free tier) at https://dashboard.voyageai.com
VOYAGE_API_KEY=pa-YOUR_VOYAGE_KEY
# VOYAGE_API_KEY_PROD_VALUE=pa-YOUR_VOYAGE_KEY


# ----------------------------------------------------------------------------
# CHAT (Node agent / Lambda)  — deploy.config.json: target=terraform
# (SECRET_KEY above is shared — do not duplicate it here.)
# ----------------------------------------------------------------------------

# Local dev port for the chat Node server (default 8100; local-only, not deployed)
CHAT_PORT=8100

# MCP server service token (ADR-033) — shared by backend (server) + chat (client).
# Authenticates the agent→MCP RPC. Generate with: openssl rand -hex 32
MCP_SERVICE_TOKEN=YOUR_MCP_SERVICE_TOKEN
# MCP_SERVICE_TOKEN_PROD_VALUE=YOUR_MCP_SERVICE_TOKEN

# MCP server URL — local points at jbemcp (localhost:8001); prod is the McpServer
# Lambda Function URL (fill PROD_VALUE after `jpushapi` prints McpServerUrl).
MCP_SERVER_URL=http://localhost:8001
# MCP_SERVER_URL_PROD_VALUE=https://YOUR-mcp-function-url.lambda-url.us-east-1.on.aws

# Upstash Redis (REST/HTTP) — ephemeral chat session store (Phase 6B).
# Get from the Upstash console → your DB → REST API section.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_URL_PROD_VALUE=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# UPSTASH_REDIS_REST_TOKEN_PROD_VALUE=your-upstash-token

# Anthropic API key (Phase 7C) — the chat agent's LLM (Claude). Pay-per-token.
# Get one at https://console.anthropic.com → API Keys (needs billing). Starts sk-ant-.
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY
# ANTHROPIC_API_KEY_PROD_VALUE=sk-ant-REPLACE_WITH_YOUR_KEY
# Optional overrides (have sensible defaults in anthropicClient.js):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=2048


# ----------------------------------------------------------------------------
# FRONTEND (React / Vercel)  — deploy.config.json: target=vercel
# REACT_APP_* are build-time vars baked into the bundle. Vercel reads these from its
# own env store (not propagated from GitHub Secrets unless 9E's CD pushes them).
# ----------------------------------------------------------------------------

# Backend API URL — local: FastAPI server; prod: API Gateway endpoint
REACT_APP_API_URL=http://localhost:8000
# REACT_APP_API_URL_PROD_VALUE=https://your-lambda-api-url.execute-api.us-east-1.amazonaws.com/prod

# Chat backend URL (Phase 6C) — local: chat Node server; prod: chat Lambda Function URL
REACT_APP_CHAT_URL=http://localhost:8100
# REACT_APP_CHAT_URL_PROD_VALUE=https://your-chat-function-url.lambda-url.us-east-1.on.aws

# Google OAuth Client ID — same value as backend GOOGLE_CLIENT_ID
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_CLIENT_ID_PROD_VALUE=your-google-client-id.apps.googleusercontent.com
